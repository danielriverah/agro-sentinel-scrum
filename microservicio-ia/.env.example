APP_ENV=local
AWS_REGION=us-east-1
CONFIG_TABLE_NAME=agro_sentinel_config
CONFIG_PARTITION_KEY=local
CONFIG_SORT_KEY=active
CONFIG_CACHE_TTL_SECONDS=60
CONFIG_FAIL_FAST=true

# Minimo para IA standalone (Bedrock Claude):
LARAVEL_WEBHOOK_URL=
LARAVEL_WEBHOOK_SECRET=
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
# Autenticacion Bedrock:
# iam     => usa AWS_ACCESS_KEY_ID_CUSTOM/AWS_SECRET_ACCESS_KEY_CUSTOM
# api_key => usa BEDROCK_API_KEY (token larga duracion de Bedrock)
BEDROCK_AUTH_MODE=iam
BEDROCK_API_KEY=

# DynamoDB local (desarrollo):
DYNAMODB_ENDPOINT_URL=http://dynamodb-local:8000

# DynamoDB AWS (produccion):
DYNAMODB_USE_AWS=false
AWS_ACCESS_KEY_ID_CUSTOM=
AWS_SECRET_ACCESS_KEY_CUSTOM=
AWS_SESSION_TOKEN_CUSTOM=
