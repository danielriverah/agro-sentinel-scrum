APP_ENV=local
AWS_REGION=us-east-1
CONFIG_TABLE_NAME=agro_sentinel_config
CONFIG_PARTITION_KEY=local
CONFIG_SORT_KEY=active
CONFIG_CACHE_TTL_SECONDS=60
CONFIG_FAIL_FAST=true
# Minimo para TIF standalone:
IA_SERVICE_URL=http://agro-ia:8002
MONITORING_S3_BUCKET=
MONITORING_S3_PREFIX=
PRODUCTIONS_API_URL=
PRODUCTIONS_API_TOKEN=

# DynamoDB local (desarrollo):
DYNAMODB_ENDPOINT_URL=http://dynamodb-local:8000

# DynamoDB AWS (produccion):
# true => usa DynamoDB AWS real (ignora endpoint local)
DYNAMODB_USE_AWS=false
AWS_ACCESS_KEY_ID_CUSTOM=
AWS_SECRET_ACCESS_KEY_CUSTOM=
AWS_SESSION_TOKEN_CUSTOM=
